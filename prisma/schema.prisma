// Prisma schema for honeking-reservation
// Phase 2: ここから本テーブル設計を順次追加していく。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 店舗マスタ
model Store {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // URL 用（例: "otakanomori", "matsudo-higashi"）
  prefecture   String // 都道府県（例: "千葉県"）
  city         String // 市区町村（例: "流山市", "松戸市"）将来の市区町村フィルタ用
  name         String
  address      String
  phone        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  beds          Bed[]
  practitioners Practitioner[]
  menus         Menu[]
  businessHours BusinessHour[]
  holidays      Holiday[]
  closures      Closure[]
  reservations  Reservation[]
  // ヘルプ勤務の back-relation: Shift.workStoreId が指す Shift 一覧。
  // メイン所属（Practitioner.storeId）とは別。null の Shift はメイン店舗で勤務する想定。
  workShifts    Shift[]        @relation("ShiftWorkStore")
}

// ベッド（店舗ごとに3〜4台）
model Bed {
  id           Int      @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  reservations Reservation[]

  @@unique([storeId, name])
  @@index([storeId])
}

// スタッフ（施術者・受付・店長・オーナーを含む店舗の所属者）
// 「予約に割り当てられるか」と「ログインできるか」を別フラグで管理し、
// 施術しない受付や店長もここに集約する。
//
// - isAssignable: 予約・シフトに割り当てられるか（false = 受付・経理など施術しない人）
// - canLogin: 管理画面にログインできるか（false = 施術専門で管理画面を触らない人）
// - canLogin = true の人は username / passwordHash / role が必須（DB CHECK で担保するのが理想だが、現状は API 層で保証）
model Practitioner {
  id           Int      @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  // 予約割当可否（施術者なら true、受付・経理なら false）
  isAssignable Boolean  @default(true)

  // ログイン情報（canLogin=false ならすべて null/空でよい）
  canLogin     Boolean  @default(false)
  username     String?  @unique
  passwordHash String?
  role         Role?
  permissions  String[] @default([])
  totpSecret   String? // Phase 5 で 2FA 有効化用

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shifts       Shift[]
  reservations Reservation[]

  @@index([storeId])
}

// メニュー
// storeId が null = 共通メニュー（全店舗で自動利用可能）
// storeId が非null = その店舗の特別メニュー（その店舗でのみ利用可能）
// お客様側は storeId IS NULL OR storeId = <currentStoreId> で取得する
model Menu {
  id              Int       @id @default(autoincrement())
  storeId         Int?
  name            String
  description     String? // 施術の説明（任意・複数行可）
  durationMinutes Int
  priceJpy        Int
  displayOrder    Int       @default(0)
  isActive        Boolean   @default(true)
  // 表示期間（任意・null = 制限なし）
  // 予約対象日が [availableFrom, availableUntil] の範囲内のときのみお客様側に表示する
  // 例: オープン記念キャンペーンメニュー
  availableFrom   DateTime? @db.Date
  availableUntil  DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  reservations Reservation[]

  // (storeId, name) は店舗特別メニューの一意性を保証する。
  // 共通メニュー（storeId IS NULL）の name 重複防止は migration の部分 unique index で対応。
  @@unique([storeId, name])
  @@index([storeId])
}

// 曜日別営業時間レンジ（1 日に 1 つ以上）
// 店休 = その (storeId, dayOfWeek) の行が 0 件
// 中抜け休憩は 2 つのレンジで表現する（例: 9:30-12:30, 15:00-20:30 = 12:30-15:00 が休憩）
model BusinessHour {
  id        Int      @id @default(autoincrement())
  storeId   Int
  dayOfWeek Int // 0=日, 1=月, 2=火, 3=水, 4=木, 5=金, 6=土
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, dayOfWeek, startTime])
  @@index([storeId, dayOfWeek])
}

// 不定期休業日（年末年始・お盆・特別休業など）
// 営業しない日。Holiday に該当する日は予約枠ゼロ。
model Holiday {
  id        Int      @id @default(autoincrement())
  storeId   Int
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, date])
  @@index([storeId, date])
}

// 部分閉店（イレギュラーで一定時間だけ休み・同日複数行可）
// 終日休みは Holiday テーブルで表現する（こちらは時間レンジ必須）
// 例: 2026-06-15 14:00-16:00 設備点検で閉店
model Closure {
  id        Int      @id @default(autoincrement())
  storeId   Int
  date      DateTime @db.Date
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, date, startTime])
  @@index([storeId, date])
}

// 国の祝日（全店舗共通・営業はするが「日曜扱い」で運用）
// アプリ層は date が PublicHoliday に該当する日は BusinessHour の dayOfWeek=0（日曜）を引く。
model PublicHoliday {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 施術者シフト（1施術者×1日=1行）
// workStoreId が指定された日は、メイン店舗（Practitioner.storeId）ではなく workStore でヘルプ勤務する。
// null の場合はメイン店舗で勤務（通常運用）。
model Shift {
  id             Int      @id @default(autoincrement())
  practitionerId Int
  date           DateTime @db.Date
  startTime      String // "HH:MM"
  endTime        String // "HH:MM"
  workStoreId    Int? // null ならメイン店舗で勤務、指定があればヘルプ先店舗
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  workStore    Store?       @relation("ShiftWorkStore", fields: [workStoreId], references: [id], onDelete: Restrict)

  @@unique([practitionerId, date])
  @@index([practitionerId, date])
  @@index([date])
  @@index([workStoreId, date])
}

// 予約ステータス
enum ReservationStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// スタッフの役職
// 役職は「呼び方」と「初期権限テンプレート」の役目。
// 実際の権限制御は Practitioner.permissions（個別上書き）と shared/permissions.ts の
// ROLE_DEFAULT_PERMISSIONS を合成して判定する。
enum Role {
  OWNER        // オーナー（経営者）: 全権限
  MANAGER      // 店長: ほぼ全権限（スタッフ管理含む）
  RECEPTIONIST // 受付: 予約管理中心
  PRACTITIONER // 施術者: 自分のシフト・予約閲覧中心
}

// 顧客（個人情報は AES-256-GCM で暗号化された値を保存。検索は *Hash カラムで行う）
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  nameHash  String   @unique
  phone     String?
  phoneHash String?  @unique
  email     String?
  emailHash String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]
}

// 予約（1ベッド + 1施術者 + 1メニュー + 時間帯）
model Reservation {
  id               Int               @id @default(autoincrement())
  storeId          Int
  bedId            Int
  practitionerId   Int
  menuId           Int
  customerId       Int
  startAt          DateTime
  endAt            DateTime
  status           ReservationStatus @default(CONFIRMED)
  confirmationCode String            @unique
  note             String?
  cancelledAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  bed          Bed          @relation(fields: [bedId], references: [id], onDelete: Restrict)
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  menu         Menu         @relation(fields: [menuId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([storeId, startAt])
  @@index([practitionerId, startAt])
  @@index([bedId, startAt])
  @@index([customerId])
  @@index([startAt])
}
