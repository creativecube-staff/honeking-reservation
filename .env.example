# ==============================================================================
# Honeking Reservation - 環境変数テンプレート
# ------------------------------------------------------------------------------
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env は Git にコミットされません（.gitignore で除外済み）
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase PostgreSQL (東京リージョン: ap-northeast-1)
# ------------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → Database → Connection string
# から取得してください。Prisma は 2 種類の URL を使い分けます。

# 通常クエリ用: Connection Pooling (Transaction mode, port 6543)
# Supabase ダッシュボードの "Transaction" モードの URI をそのまま貼り付け
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# マイグレーション用: Direct connection (port 5432)
# Supabase ダッシュボードの "Session" モードの URI、もしくは Direct connection の URI
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------------------------
# Supabase Project API
# ------------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API から取得
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY=""

# ⚠ サーバーサイド専用。クライアントには絶対に露出させない
SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------------------------------------------
# アプリケーション層の暗号化
# ------------------------------------------------------------------------------
# 個人情報 (電話番号・メール) を AES-256-GCM で暗号化するためのキー。
# 32 バイト (64 hex 文字) を生成して設定:
#   openssl rand -hex 32
ENCRYPTION_KEY=""

# ------------------------------------------------------------------------------
# nuxt-auth-utils セッション暗号化
# ------------------------------------------------------------------------------
# 管理画面ログインのセッションクッキー暗号化用。32 文字以上を必須。
#   openssl rand -base64 32
NUXT_SESSION_PASSWORD=""
