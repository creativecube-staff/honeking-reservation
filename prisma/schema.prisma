// Prisma schema for honeking-reservation
// Phase 2: ここから本テーブル設計を順次追加していく。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 店舗マスタ
model Store {
  id           Int      @id @default(autoincrement())
  name         String
  address      String
  phone        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  beds          Bed[]
  practitioners Practitioner[]
  menus         Menu[]
  businessHours BusinessHour[]
  holidays      Holiday[]
}

// ベッド（店舗ごとに3〜4台）
model Bed {
  id           Int      @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, name])
  @@index([storeId])
}

// 施術者（店舗固定、掛け持ちなし）
model Practitioner {
  id           Int      @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shifts Shift[]

  @@index([storeId])
}

// メニュー（店舗ごと個別）
model Menu {
  id              Int      @id @default(autoincrement())
  storeId         Int
  name            String
  durationMinutes Int
  priceJpy        Int
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, name])
  @@index([storeId])
}

// 曜日別営業時間（店舗ごとに7行: 日〜土）
model BusinessHour {
  id             Int      @id @default(autoincrement())
  storeId        Int
  dayOfWeek      Int // 0=日, 1=月, 2=火, 3=水, 4=木, 5=金, 6=土
  isClosed       Boolean  @default(false)
  openTime       String? // "HH:MM"
  closeTime      String? // "HH:MM"
  breakStartTime String? // "HH:MM"
  breakEndTime   String? // "HH:MM"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, dayOfWeek])
  @@index([storeId])
}

// 不定期休業日（年末年始・お盆・特別休業など）
model Holiday {
  id        Int      @id @default(autoincrement())
  storeId   Int
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, date])
  @@index([storeId, date])
}

// 施術者シフト（1施術者×1日=1行）
model Shift {
  id             Int      @id @default(autoincrement())
  practitionerId Int
  date           DateTime @db.Date
  startTime      String // "HH:MM"
  endTime        String // "HH:MM"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Restrict)

  @@unique([practitionerId, date])
  @@index([practitionerId, date])
  @@index([date])
}
