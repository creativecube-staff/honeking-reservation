// Prisma schema for honeking-reservation
// Phase 2: ここから本テーブル設計を順次追加していく。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 店舗マスタ
model Store {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // URL 用（例: "otakanomori", "matsudo-higashi"）
  prefecture   String // 都道府県（例: "千葉県"）
  city         String // 市区町村（例: "流山市", "松戸市"）将来の市区町村フィルタ用
  name         String
  address      String
  phone        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  beds          Bed[]
  practitioners Practitioner[]
  menus         Menu[]
  businessHours BusinessHour[]
  holidays      Holiday[]
  closures      Closure[]
  reservations  Reservation[]
  products      Product[]
  productSales  ProductSale[]
  // ヘルプ勤務の back-relation: Shift.workStoreId が指す Shift 一覧。
  // メイン所属（Practitioner.storeId）とは別。null の Shift はメイン店舗で勤務する想定。
  workShifts    Shift[]        @relation("ShiftWorkStore")
}

// ベッド（店舗ごとに3〜4台）
model Bed {
  id           Int      @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  reservations Reservation[]

  @@unique([storeId, name])
  @@index([storeId])
}

// スタッフ（施術者・受付・店長・オーナーを含む店舗の所属者）
// 「予約に割り当てられるか」と「ログインできるか」を別フラグで管理し、
// 施術しない受付や店長もここに集約する。
//
// - isAssignable: 予約・シフトに割り当てられるか（false = 受付・経理など施術しない人）
// - canLogin: 管理画面にログインできるか（false = 施術専門で管理画面を触らない人）
// - canLogin = true の人は username / passwordHash / role が必須（DB CHECK で担保するのが理想だが、現状は API 層で保証）
model Practitioner {
  id           Int     @id @default(autoincrement())
  storeId      Int
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  // 予約割当可否（施術者なら true、受付・経理なら false）
  isAssignable Boolean @default(true)

  // ログイン情報（canLogin=false ならすべて null/空でよい）
  canLogin     Boolean  @default(false)
  username     String?  @unique
  passwordHash String?
  role         Role?
  permissions  String[] @default([])
  totpSecret   String? // Phase 5 で 2FA 有効化用

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shifts       Shift[]
  reservations Reservation[]
  soldSales    ProductSale[]

  @@index([storeId])
}

// メニュー
// storeId が null = 共通メニュー（全店舗で自動利用可能）
// storeId が非null = その店舗の特別メニュー（その店舗でのみ利用可能）
// お客様側は storeId IS NULL OR storeId = <currentStoreId> で取得する
model Menu {
  id              Int       @id @default(autoincrement())
  storeId         Int?
  name            String
  description     String? // 施術の説明（任意・複数行可）
  durationMinutes Int
  priceJpy        Int
  displayOrder    Int       @default(0)
  isActive        Boolean   @default(true)
  // 表示期間（任意・null = 制限なし）
  // 予約対象日が [availableFrom, availableUntil] の範囲内のときのみお客様側に表示する
  // 例: オープン記念キャンペーンメニュー
  availableFrom   DateTime? @db.Date
  availableUntil  DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  reservations Reservation[]

  // (storeId, name) は店舗特別メニューの一意性を保証する。
  // 共通メニュー（storeId IS NULL）の name 重複防止は migration の部分 unique index で対応。
  @@unique([storeId, name])
  @@index([storeId])
}

// 曜日別営業時間レンジ（1 日に 1 つ以上）
// 店休 = その (storeId, dayOfWeek) の行が 0 件
// 中抜け休憩は 2 つのレンジで表現する（例: 9:30-12:30, 15:00-20:30 = 12:30-15:00 が休憩）
model BusinessHour {
  id        Int      @id @default(autoincrement())
  storeId   Int
  dayOfWeek Int // 0=日, 1=月, 2=火, 3=水, 4=木, 5=金, 6=土
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, dayOfWeek, startTime])
  @@index([storeId, dayOfWeek])
}

// 不定期休業日（年末年始・お盆・特別休業など）
// 営業しない日。Holiday に該当する日は予約枠ゼロ。
model Holiday {
  id        Int      @id @default(autoincrement())
  storeId   Int
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, date])
  @@index([storeId, date])
}

// 部分閉店（イレギュラーで一定時間だけ休み・同日複数行可）
// 終日休みは Holiday テーブルで表現する（こちらは時間レンジ必須）
// 例: 2026-06-15 14:00-16:00 設備点検で閉店
model Closure {
  id        Int      @id @default(autoincrement())
  storeId   Int
  date      DateTime @db.Date
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([storeId, date, startTime])
  @@index([storeId, date])
}

// 国の祝日（全店舗共通・営業はするが「日曜扱い」で運用）
// アプリ層は date が PublicHoliday に該当する日は BusinessHour の dayOfWeek=0（日曜）を引く。
model PublicHoliday {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 施術者シフト（1施術者×1日=1行）
// workStoreId が指定された日は、メイン店舗（Practitioner.storeId）ではなく workStore でヘルプ勤務する。
// null の場合はメイン店舗で勤務（通常運用）。
model Shift {
  id             Int      @id @default(autoincrement())
  practitionerId Int
  date           DateTime @db.Date
  startTime      String // "HH:MM"
  endTime        String // "HH:MM"
  workStoreId    Int? // null ならメイン店舗で勤務、指定があればヘルプ先店舗
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  workStore    Store?       @relation("ShiftWorkStore", fields: [workStoreId], references: [id], onDelete: Restrict)

  @@unique([practitionerId, date])
  @@index([practitionerId, date])
  @@index([date])
  @@index([workStoreId, date])
}

// 予約ステータス
// 「完了」は明示的なステータスを持たず、CONFIRMED かつ終了時刻が過去という条件で
// アプリ層が自動判定する（shared/reservationStatus.ts の displayStatus 参照）。
enum ReservationStatus {
  CONFIRMED
  CANCELLED
  NO_SHOW
}

// 商品種別
// PRODUCT = 物販（在庫あり）、VOUCHER = 回数券（在庫概念なし、N 回分）
enum ProductKind {
  PRODUCT
  VOUCHER
}

// スタッフの役職
// 役職は「呼び方」と「初期権限テンプレート」の役目。
// 実際の権限制御は Practitioner.permissions（個別上書き）と shared/permissions.ts の
// ROLE_DEFAULT_PERMISSIONS を合成して判定する。
enum Role {
  OWNER // オーナー（経営者）: 全権限
  MANAGER // 店長: ほぼ全権限（スタッフ管理含む）
  RECEPTIONIST // 受付: 予約管理中心
  PRACTITIONER // 施術者: 自分のシフト・予約閲覧中心
}

// 顧客（個人情報は AES-256-GCM で暗号化された値を保存。検索は *Hash カラムで行う）
//
// 会員制（Phase 1〜）について:
// - passwordHash がセットされている顧客 = 会員登録済み
// - emailVerifiedAt がセットされている顧客 = 本登録完了（メール認証済み）
// - ゲスト予約のみの顧客は passwordHash も emailVerifiedAt も null
// - 仮登録段階（メール認証待ち）は passwordHash あり / emailVerifiedAt null
model Customer {
  id              Int       @id @default(autoincrement())
  name            String
  // nameHash: 暗号化された name を検索可能にするための SHA-256 ハッシュ。
  // unique 制約は付けない（同姓同名の顧客が現実に存在するため）。
  // 検索性能のために通常 index は維持する。
  nameHash        String
  phone           String?
  phoneHash       String?   @unique
  email           String?
  emailHash       String?   @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  // 会員規約・プライバシーポリシーへの同意記録（消費者契約法・定型約款対策）
  // 同意した時点のバージョン文字列（例: "v1.0-2026-05-13"）も併記し、後で規約改定時の追跡を可能にする
  termsAgreedAt          DateTime?
  termsVersionAgreedAt   String?
  // 管理者専用の接客メモ（PII を書かない前提のため暗号化なし）
  // 例: 「腰痛持ち」「○○の話で盛り上がる」「左肩のみ施術不可」
  note                   String?
  // 退会日時。null = 退会していない（ゲストか会員）。
  // 退会時は passwordHash / emailVerifiedAt / lastLoginAt / termsAgreedAt 等もクリアされる（withdraw.post.ts 参照）
  // 暗号化済 name / phone / email は残し、来店履歴を保持する
  withdrawnAt            DateTime?
  // LINE 連携情報
  // lineUserId: LINE Login で取得できるユーザー固有 ID（"U" で始まる 33 文字）。
  // 1 顧客 = 0 or 1 LINE アカウント。null = 未連携。退会時はクリア。
  // lineDisplayName: 連携時点の LINE プロフィール表示名。マイページ「LINE と連携中」表記用（PII としては緩い）。
  lineUserId             String?   @unique
  lineDisplayName        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  reservations            Reservation[]
  productSales            ProductSale[]
  vouchers                CustomerVoucher[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  emailChangeTokens       EmailChangeToken[]

  // 管理画面の顧客検索・予約検索で nameHash 完全一致を引くため非ユニークの index を付ける
  @@index([nameHash])
}

// 会員仮登録 → 本登録の中継トークン
// 仮登録時に発行 → メールリンククリックで Customer.emailVerifiedAt を set + 該当トークンを usedAt set
// 期限切れトークンは別途バッチで削除（当面は手運用でも問題ない量）
model EmailVerificationToken {
  id         Int       @id @default(autoincrement())
  customerId Int
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([customerId])
}

// パスワードリセットトークン
// 「リセットメール送って」リクエストで発行 → リンクから新パスワード設定で usedAt set
// 存在しないメアドへのリクエストも 200 を返す（メアド存在の漏洩防止）ためトークン発行は実在ユーザーのみ
model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  customerId Int
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([customerId])
}

// メアド変更トークン
// マイページから「メアドを変更」した時点で発行 → 新メアド宛にリンク送信 → クリックで Customer.email/emailHash を更新
// 確定までは古いメアドが有効なので、未確定状態でも会員機能は使い続けられる
// 新メアド (newEmail) はアプリ層で AES-256-GCM 暗号化、newEmailHash は SHA-256 で一意性確認用
model EmailChangeToken {
  id            Int       @id @default(autoincrement())
  customerId    Int
  newEmail      String // 暗号化値
  newEmailHash  String // sha256 (一意性確認・重複登録防止)
  token         String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([newEmailHash])
}

// 予約（1ベッド + 1施術者 + 1メニュー + 時間帯）
model Reservation {
  id               Int               @id @default(autoincrement())
  storeId          Int
  bedId            Int
  practitionerId   Int
  menuId           Int
  customerId       Int
  startAt          DateTime
  endAt            DateTime
  status           ReservationStatus @default(CONFIRMED)
  confirmationCode String            @unique
  note             String?
  cancelledAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  store        Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  bed          Bed                  @relation(fields: [bedId], references: [id], onDelete: Restrict)
  practitioner Practitioner         @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  menu         Menu                 @relation(fields: [menuId], references: [id], onDelete: Restrict)
  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  histories    ReservationHistory[]
  productSales ProductSale[]
  // 1 予約 = 0 or 1 回数券消費。VoucherUsage が存在すると売上ゼロ扱い
  voucherUsage VoucherUsage?

  @@index([storeId, startAt])
  @@index([practitionerId, startAt])
  @@index([bedId, startAt])
  @@index([customerId])
  @@index([startAt])
}

// 予約の変更履歴（時間変更・メニュー変更・スタッフ/ベッド変更・ステータス変更を 1 行ずつ記録）
// changedByPractitionerId は操作した管理ユーザー（Practitioner）。削除時の影響を避けるため nullable。
// changedByName は操作時点での名前を別途保存し、後で名前を変えても履歴の表示が壊れないようにする。
model ReservationHistory {
  id                      Int      @id @default(autoincrement())
  reservationId           Int
  changedAt               DateTime @default(now())
  changedByPractitionerId Int?
  changedByName           String

  // 変更前のスナップショット
  prevStartAt        DateTime
  prevEndAt          DateTime
  prevStatus         ReservationStatus
  prevMenuId         Int
  prevPractitionerId Int
  prevBedId          Int

  // 変更後のスナップショット
  newStartAt        DateTime
  newEndAt          DateTime
  newStatus         ReservationStatus
  newMenuId         Int
  newPractitionerId Int
  newBedId          Int

  note String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Restrict)

  @@index([reservationId, changedAt])
}

// 商品マスタ
// kind=PRODUCT: 物販。stock を消費する。
// kind=VOUCHER: 回数券。stock は使わず、voucherTotalUses が「1 枚あたりの利用回数」。
// storeId=null は共通商品（全店で販売可）、指定すると店舗特別商品。
// メニュー設計と同じ二階建て。
model Product {
  id               Int         @id @default(autoincrement())
  storeId          Int?
  kind             ProductKind @default(PRODUCT)
  name             String
  description      String?
  priceJpy         Int
  // 物販時のみ意味を持つ在庫数。VOUCHER では 0 のまま使わない。
  stock            Int         @default(0)
  // VOUCHER 専用: 1 枚購入したら何回分の施術が受けられるか（例: 10）
  voucherTotalUses Int?
  isActive         Boolean     @default(true)
  displayOrder     Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  store    Store?            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  sales    ProductSale[]
  vouchers CustomerVoucher[]

  // (storeId, name) で店舗特別商品の一意性を保証。共通商品（storeId IS NULL）の重複防止は migration 側の部分 unique index で対応する。
  @@unique([storeId, name])
  @@index([storeId])
  @@index([kind])
}

// 販売記録（物販 + 回数券販売の両方）
// unitPriceJpyAtSale は販売時点での単価スナップショット。後で priceJpy を変えても履歴は残る。
// reservationId は紐付け任意。「来店ついでに購入」のときは設定する。
model ProductSale {
  id                   Int      @id @default(autoincrement())
  productId            Int
  storeId              Int
  customerId           Int
  reservationId        Int?
  quantity             Int
  unitPriceJpyAtSale   Int
  soldAt               DateTime @default(now())
  soldByPractitionerId Int?
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  product            Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  store              Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  reservation        Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  soldByPractitioner Practitioner?    @relation(fields: [soldByPractitionerId], references: [id], onDelete: Restrict)
  // 回数券販売（kind=VOUCHER）のときに 1 対 1 で発行される
  voucher            CustomerVoucher?

  @@index([storeId, soldAt])
  @@index([customerId])
  @@index([reservationId])
  @@index([productId])
}

// 顧客が保有している回数券（販売 1 件 = 回数券 1 枚）
// 残回数 0 になっても物理削除はせず、履歴として残す。
model CustomerVoucher {
  id            Int      @id @default(autoincrement())
  customerId    Int
  productId     Int
  productSaleId Int      @unique
  totalUses     Int
  remainingUses Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product     Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  productSale ProductSale    @relation(fields: [productSaleId], references: [id], onDelete: Restrict)
  usages      VoucherUsage[]

  @@index([customerId])
}

// 予約に対する回数券消費。1 予約 = 0 または 1 回まで（reservationId に unique 制約）。
// この行が存在する予約は売上ゼロ扱い（回数券販売日に売上計上済みのため）。
model VoucherUsage {
  id                Int      @id @default(autoincrement())
  customerVoucherId Int
  reservationId     Int      @unique
  usedAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  customerVoucher CustomerVoucher @relation(fields: [customerVoucherId], references: [id], onDelete: Restrict)
  reservation     Reservation     @relation(fields: [reservationId], references: [id], onDelete: Restrict)

  @@index([customerVoucherId])
}
