# ローカル開発用リバースプロキシ。本番想定にできるだけ寄せる。
# .localhost ドメインは Caddy の内部 CA で自動 HTTPS 化される
# 本番では別途 docker-compose.prod.yml で Let's Encrypt 付きの Caddyfile を用意

# ======================================
# 共通セキュリティヘッダ（本番でも流用する想定）
# ======================================
(security_headers) {
	header {
		# クリックジャッキング防止
		X-Frame-Options "DENY"
		# MIME sniffing 防止
		X-Content-Type-Options "nosniff"
		# Referer ポリシー（外部に余計な情報を漏らさない）
		Referrer-Policy "strict-origin-when-cross-origin"
		# サーバ情報を隠す
		-Server

		# 本番では以下も有効化する：
		# Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Content-Security-Policy "default-src 'self'; ..."
		# Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# ======================================
# 共通 reverse_proxy 設定（WebSocket / HMR 透過）
# ======================================
(nuxt_upstream) {
	reverse_proxy nuxt:3000 {
		# X-Forwarded-* ヘッダは Caddy がデフォルトで付与
		# WebSocket（Vite HMR）も自動的に透過
	}
}

# ======================================
# 共通エラーハンドラ（静的 404 ページを返す）
#
# `error <code>` でリクエスト処理を中断 → handle_errors で静的 HTML をサーブ。
# レスポンスは「Status 404 + 完全な HTML 本文」になる。
# ======================================
(error_pages) {
	handle_errors {
		rewrite * /404.html
		root * /srv/error-pages
		file_server
	}
}

# ======================================
# お客様向け予約サイト
# ======================================
reserve.honeking.localhost {
	import security_headers

	# /dashboard* は admin ホスト専用なので 404 で隠す（情報隠蔽）
	@admin_paths path /dashboard /dashboard/* /api/admin /api/admin/*
	handle @admin_paths {
		error 404
	}

	import nuxt_upstream
	import error_pages
}

# ======================================
# 管理画面
# ======================================
admin.honeking.localhost {
	import security_headers

	# Basic 認証ゲート（アプリログイン前段、多層防御）
	# - .env の ADMIN_USER / ADMIN_PASSWORD_HASH（bcrypt）を使用
	# - パスワード生成: docker compose exec caddy caddy hash-password
	basicauth {
		{$ADMIN_USER} {$ADMIN_PASSWORD_HASH}
	}

	# 本番では admin ホストに IP allowlist もかける想定（ローカルでは無効）
	# @office_ip remote_ip 203.0.113.0/24
	# @disallowed not remote_ip 203.0.113.0/24
	# handle @disallowed {
	#     respond "Forbidden" 403
	# }

	# / は /dashboard へリダイレクト（admin ホストのトップは即ダッシュボードへ）
	@root path /
	handle @root {
		redir * /dashboard 302
	}

	# 許可するパス：/login（共有ログイン、host-aware）+ /dashboard* + API + Nuxt 内部
	# /api/_* は Nuxt UI のアイコン API（/api/_nuxt_icon）等のフレームワーク内部 API。
	# 将来 Nuxt モジュールが追加する内部 API も /api/_xxx という命名規約なので一括許可。
	# /admin-favicon-* は管理画面のモノクロファビコン（public/admin-favicon-*.png）。
	@admin_allowed path /login \
		/dashboard /dashboard/* \
		/api/admin /api/admin/* /api/_* \
		/_nuxt* /__nuxt* /_payload* /_ipx* /__vite* \
		/favicon.ico /robots.txt /apple-touch-icon.png /admin-favicon-*
	handle @admin_allowed {
		import nuxt_upstream
	}

	# 上記に該当しないものは全て edge で 404
	handle {
		error 404
	}

	import error_pages
}
